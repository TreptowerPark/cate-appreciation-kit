{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "noEmit": true,
    "types": ["vitest/globals"]
  },
  "include": [
    "packages/**/*.ts",
    "examples/**/*.ts",
    "examples/**/*.tsx",
    "tests/**/*.ts"
  ]
}
